<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ofuscador y Minificador Web</title>
    
    <script src="https://cdn.jsdelivr.net/npm/javascript-obfuscator/dist/index.browser.js"></script>
    
    <style>
        :root {
            --bg-color: #1e1e2f;
            --text-color: #c8c8c8;
            --accent: #6c5ce7;
            --editor-bg: #2d2d44;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
            max-width: 800px;
            margin: 0 auto;
        }
        h1 { text-align: center; color: #fff; }
        .controls {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        select, button {
            padding: 10px 15px;
            font-size: 16px;
            border-radius: 5px;
            border: none;
            outline: none;
        }
        select {
            background-color: var(--editor-bg);
            color: white;
            border: 1px solid #444;
        }
        button {
            background-color: var(--accent);
            color: white;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }
        button:hover { background-color: #5b4bc4; }
        textarea {
            width: 100%;
            height: 250px;
            background-color: var(--editor-bg);
            color: #00ffcc; /* Color estilo terminal para el código */
            border: 1px solid #444;
            border-radius: 5px;
            padding: 15px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            resize: vertical;
            box-sizing: border-box;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <h1>Ofuscador de Código</h1>

    <div class="controls">
        <select id="lenguaje">
            <option value="js">JavaScript (Ofuscar)</option>
            <option value="html">HTML (Minificar)</option>
            <option value="css">CSS (Minificar)</option>
        </select>
        <button onclick="procesarCodigo()">Procesar Código</button>
    </div>

    <label for="inputCode"><strong>Código Original:</strong></label>
    <textarea id="inputCode" placeholder="Pega tu código aquí..."></textarea>

    <div class="controls">
        <label for="outputCode"><strong>Resultado:</strong></label>
        <button onclick="copiarAlPortapapeles()" style="background-color: #00b894;">Copiar Resultado</button>
    </div>
    <textarea id="outputCode" readonly placeholder="El código procesado aparecerá aquí..."></textarea>

    <script>
        function procesarCodigo() {
            const lenguaje = document.getElementById('lenguaje').value;
            const codigoEntrada = document.getElementById('inputCode').value;
            let codigoSalida = '';

            if (!codigoEntrada.trim()) {
                alert("Por favor, ingresa algo de código.");
                return;
            }

            try {
                if (lenguaje === 'js') {
                    // Usamos la API de javascript-obfuscator disponible en el objeto global
                    const resultadoObfuscacion = JavaScriptObfuscator.obfuscate(codigoEntrada, {
                        compact: true,
                        controlFlowFlattening: true,
                        controlFlowFlatteningThreshold: 0.75,
                        numbersToExpressions: true,
                        simplify: true,
                        stringArrayShuffle: true,
                        splitStrings: true,
                        stringArrayThreshold: 0.75
                    });
                    codigoSalida = resultadoObfuscacion.getObfuscatedCode();
                } 
                else if (lenguaje === 'html') {
                    // Minificación básica de HTML usando RegEx
                    codigoSalida = codigoEntrada
                        .replace(//g, '') // Elimina comentarios
                        .replace(/\n/g, '')              // Elimina saltos de línea
                        .replace(/\s+/g, ' ')            // Reduce múltiples espacios a uno
                        .replace(/>\s+</g, '><')         // Elimina espacios entre etiquetas
                        .trim();
                } 
                else if (lenguaje === 'css') {
                    // Minificación básica de CSS usando RegEx
                    codigoSalida = codigoEntrada
                        .replace(/\/\*[\s\S]*?\*\//g, '') // Elimina comentarios
                        .replace(/\n/g, '')               // Elimina saltos de línea
                        .replace(/\s+/g, ' ')             // Reduce espacios
                        .replace(/\s*([\{\}\:\;\,])\s*/g, '$1') // Elimina espacios alrededor de sintaxis clave
                        .trim();
                }

                document.getElementById('outputCode').value = codigoSalida;
            } catch (error) {
                document.getElementById('outputCode').value = "Error al procesar el código:\n" + error.message;
            }
        }

        function copiarAlPortapapeles() {
            const output = document.getElementById('outputCode');
            if(output.value) {
                output.select();
                document.execCommand('copy');
                alert("¡Código copiado al portapapeles!");
            }
        }
    </script>
</body>
</html>
